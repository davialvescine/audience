{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audience Desktop",
  "version": "0.1.1",
  "identifier": "app.audience.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Audience — Moderação",
        "url": "https://audience-opal.vercel.app/admin",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "transparent": false,
        "decorations": true,
        "shadow": true,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Painel de moderação Audience com janela de telão integrada",
    "longDescription": "App desktop pra moderar comentários e a nuvem de palavras do Audience com login integrado. Abre janela secundária transparente always-on-top com o telão pra projetor/transmissão.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
