{
  "name": "audience-monorepo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "db:types": "supabase gen types typescript --linked > packages/shared-types/src/database.ts"
  },
  "devDependencies": {
    "eslint": "^9.39.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.12.0"
}
